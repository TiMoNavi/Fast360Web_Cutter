# SSH alias from C:\Users\Administrator\.ssh\config
SSH_HOST=TenCent

# Public address of the Tencent server.
SERVER_ENDPOINT=81.70.52.75

# Recommended: point a domain A record to 81.70.52.75.
# Leave empty to skip Caddy HTTPS setup during server bootstrap.
PUBLIC_HOST=

# WireGuard network.
WG_PORT=51820
WG_SERVER_IP=10.77.0.1
WG_CLIENT_IP=10.77.0.2
WG_CLIENT_CIDR=10.77.0.2/32
WG_ALLOWED_IPS=10.77.0.0/24

# Caddy on the server reverse proxies HTTPS to this fixed client-side gateway port.
# The Windows script maps this fixed port to the actual local project port.
PUBLIC_WEB_GATEWAY_PORT=39080

# Local project port candidates used by Start-ProjectPublicTunnel.ps1 when -LocalWebPort is omitted.
LOCAL_WEB_PORT_CANDIDATES=3081,3000,3080
LOCAL_API_PORT_CANDIDATES=8000,8010,5000,5001

# Server-side TCP forwarding for direct public ports.
# Use "all" to forward TCP 1024-65535 to the PC through WireGuard.
# Or use a comma list, for example: 3000,3080,8000
EXPOSE_TCP=all

# Fill this after running client\New-WireGuardKeys.ps1.
CLIENT_PUBLIC_KEY=
